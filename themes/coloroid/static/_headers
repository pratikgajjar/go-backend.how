/*
  Cache-Control: public, s-maxage=60, must-revalidate
  Content-Security-Policy: default-src 'self'; script-src 'self' cdn.jsdelivr.net *.backend.how 'nonce-mermaid'; connect-src 'self' *.backend.how hn.algolia.com; frame-src 'self' www.youtube-nocookie.com; frame-ancestors 'self'; object-src 'none'; font-src 'self' cdn.jsdelivr.net; img-src 'self'; style-src 'self' 'unsafe-inline' cdn.jsdelivr.net;
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()

/fonts/*
  ! Cache-Control
  Cache-Control: public, max-age=2592000, immutable

/css/*
  ! Cache-Control
  Cache-Control: public, max-age=2592000, immutable

/js/*
  ! Cache-Control
  Cache-Control: public, max-age=2592000, immutable

/favicon.ico
  ! Cache-Control
  Cache-Control: public, max-age=2592000, stale-while-revalidate

/*.svg
  ! Cache-Control
  Cache-Control: public, max-age=2592000, stale-while-revalidate

/*.png
  ! Cache-Control
  Cache-Control: public, max-age=2592000, stale-while-revalidate

/*.webmanifest
  ! Cache-Control
  Cache-Control: public, max-age=2592000, stale-while-revalidate
